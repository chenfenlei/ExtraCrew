# ─────────────────────────────────────────────────────────────────────────────
# ExtraCrew — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and NEVER committed.
# On Vercel: paste these into Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic Claude API key — paste yours from https://console.anthropic.com
# This variable is read ONLY on the server (in /api routes).
# It is NEVER sent to the browser.
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Optional: A long random string used to sign session tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_random_secret_here

# Optional: Allowed origin for CORS (your production domain).
# Leave blank during local dev.
# ALLOWED_ORIGIN=https://extracrew.vercel.app
